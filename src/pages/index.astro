---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
const allPosts = await Astro.glob('./posts/*.md');
const getDateStr = (fm) => fm?.date ?? fm?.pubDate ?? fm?.pubdate;
const parseAsUTC = (s) => {
  if (!s) return new Date(0);
  // If date is in YYYY-MM-DD form, append Z to force UTC parsing
  return new Date(s.length === 10 ? `${s}T00:00:00Z` : s);
};
const posts = allPosts
  .filter(p => p.frontmatter && getDateStr(p.frontmatter))
  .sort((a, b) => parseAsUTC(getDateStr(b.frontmatter)) - parseAsUTC(getDateStr(a.frontmatter)))
  .slice(0, 3);
---
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>internetguy's space on the www</title>
    </head>
    <body class="dark home">
      <Navbar />
        <main>
            <section>
                <p>
                    welcome! my name is <mark>Hendry</mark>. i go by
                    <mark>justanotherinternetguy</mark> or <mark>nyaarch</mark> online
                    (i can also be found as <mark>gentoouinely</mark>). this is my personal
                    website and blog.
                    <br />
                    <br />
                    i am an incoming freshman at
                    <mark>Cornell University</mark> studying
                    <mark>computer science</mark>, <mark>mathematics</mark>, and <mark>linguistics</mark>. i am
                    generally interested in computer science, engineering, physics,
                    biology, linguistics, and deep learning.
                    <br />
                    <br />
                    i currently conduct research in the intersection of speech,
                    linguistics, deep learning, and human-machine interaction. right
                    now, i am working on deep learning methods to detect and correct
                    speech impairments (mainly stutters).
                </p>

				          <ul>
            <li>
              i use
              <a href="https://www.gentoo.org/" target="_blank">gentoo</a> and
              <a href="https://archlinux.org/" target="_blank">arch linux</a>
            </li>
            <li>
              in my free time, i enjoy learning conlangs and linguistics. i am
              learning
              <a href="https://eo.wikipedia.org/wiki/Esperanto" target="_blank"
                >esperanto</a
              >
              and <a href="https://tokipona.org/" target="_blank">toki pona.</a>
            </li>
            <li>i also am a fan of aviation, especially military aircraft</li>
            <li>
              i am an active
              <a
                href="https://en.wikipedia.org/wiki/User:Justanotherinternetguy"
                target="_blank"
              >
                wikipedia editor</a
              >
            </li>
          </ul>
            </section>
            </section>
            <section>
              <h2>Recent posts</h2>
              <ul>
                {posts.map(post => (
                  <li>
                    <a href={post.url}>{post.frontmatter.title ?? post.url}</a>
                    {getDateStr(post.frontmatter) ? (
                      <span> — {parseAsUTC(getDateStr(post.frontmatter)).toLocaleString(undefined, { timeZone: 'America/New_York', year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
                    ) : null}
                  </li>
                ))}
              </ul>
            </section>
        </main>
    </body>
</html>
