---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
const allPostModules = import.meta.glob("./posts/**/*.md", { eager: true });
const allPosts = Object.entries(allPostModules).map(([path, mod]) => {
  const url = path.replace("./posts", "/posts").replace(/\.md$/, "");
  return {
    url,
    path,
    frontmatter: mod?.frontmatter ?? {},
  };
});
const getDateStr = (fm) => fm?.date ?? fm?.pubDate ?? fm?.pubdate;
const parseAsUTC = (s) => {
  if (!s) return new Date(0);
  return new Date(s.length === 10 ? `${s}T00:00:00Z` : s);
};
const sortedPosts = allPosts
  .filter((p) => p.frontmatter && getDateStr(p.frontmatter))
  .sort(
    (a, b) =>
      parseAsUTC(getDateStr(b.frontmatter)) -
      parseAsUTC(getDateStr(a.frontmatter)),
  );
const posts = sortedPosts.slice(0, 3);
const writeupPosts = sortedPosts
  .filter((post) => post.path.includes("/writeups/"))
  .slice(0, 5);
const projectPosts = sortedPosts
  .filter((post) => post.path.includes("/project1week/"))
  .slice(0, 5);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>internetguy's space on the www</title>
  </head>
  <body class="dark home">
    <Navbar />
    <main>
      <section>
        <p>
          welcome! my name is <mark>Hendry</mark>. i go by
          <mark>justanotherinternetguy</mark> or <mark>nyaarch</mark> online (i can
          also be found as <mark>gentoouinely</mark> or <mark>internetguy</mark
          >). this is my personal website and blog.
        </p>
        <p>
          i am an incoming freshman at
          <mark>Cornell University</mark> studying
          <mark>computer science</mark>, <mark>mathematics</mark>, and <mark
            >linguistics</mark
          >. i am generally interested in computer science, engineering,
          physics, biology, linguistics, and deep learning.
          <br />
          <br />
          i currently conduct research in the intersection of speech, linguistics,
          deep learning, and human-machine interaction. right now, i am working on
          <mark>world models</mark> to simulate natural/biological environments and
          <a
            href="https://ieeexplore.ieee.org/document/11288978"
            target="_blank"
            rel="noopener noreferrer">end-to-end speech conversion.</a
          >
        </p>
        <p>
          i interned for <a
            href="https://www.synclabs.co/"
            target="_blank"
            rel="noopener noreferrer">Sync Labs</a
          > to develop facial & action recognition on IoT devices. i competed at the <a
            href="https://isef.net/project/cbio057-stutterzero-end-to-end-correction-of-stutters"
            target="_blank"
            rel="noopener noreferrer"
            >International Science and Engineering Fair 2025</a
          >, and will be returning for ISEF 2026.
        </p>
        <ul>
          <li>
            i use
            <a href="https://www.gentoo.org/" target="_blank">gentoo</a> and
            <a href="https://archlinux.org/" target="_blank">arch linux</a>
          </li>
          <li>
            in my free time, i enjoy learning conlangs and linguistics. i am
            learning
            <a href="https://eo.wikipedia.org/wiki/Esperanto" target="_blank"
              >esperanto</a
            >
            and <a href="https://tokipona.org/" target="_blank">toki pona.</a>
          </li>
          <li>i also am a fan of aviation, especially military aircraft</li>
          <li>
            i am a
            <a
              href="https://en.wikipedia.org/wiki/User:Justanotherinternetguy"
              target="_blank"
            >
              wikipedia editor</a
            >
          </li>
          <li>contact me on discord <mark>@justanotherinternetguy</mark></li>
        </ul>
      </section>
      <div class="home-post-layout">
        <section class="home-post-sidebar">
          <h2>CTF Writeups</h2>
          <ul>
            {
              writeupPosts.map((post) => (
                <li>
                  <a href={post.url}>{post.frontmatter.title ?? post.url}</a>
                </li>
              ))
            }
          </ul>
        </section>
        <section class="home-post-main">
          <h2>Recent posts</h2>
          <ul>
            {
              posts.map((post) => (
                <li>
                  <a href={post.url}>{post.frontmatter.title ?? post.url}</a>
                  {getDateStr(post.frontmatter) ? (
                    <span>
                      {" "}
                      —{" "}
                      {parseAsUTC(getDateStr(post.frontmatter)).toLocaleString(
                        undefined,
                        {
                          timeZone: "America/New_York",
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                          hour: "2-digit",
                          minute: "2-digit",
                        },
                      )}
                    </span>
                  ) : null}
                </li>
              ))
            }
          </ul>
        </section>
        <section class="home-post-sidebar">
          <h2>Project 1Week</h2>
          <ul>
            {
              projectPosts.map((post) => (
                <li>
                  <a href={post.url}>{post.frontmatter.title ?? post.url}</a>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </main>
  </body>
</html>
