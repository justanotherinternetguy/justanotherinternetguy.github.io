--- 
import { FaGithub, FaMastodon } from "react-icons/fa6";
const pathname = Astro.url.pathname;
const pageName = pathname === '/' ? 'home' : pathname.replace(/^\/+|\/+$/g, '');
---
<nav class="site-nav glass" role="navigation" aria-label="Main navigation">
  <div class="brand font-birch">
    <a href="/" class="brand-link">
      <span class="logo">internetguy.dev/{pageName}</span>
    </a>
  </div>
  <div class="nav-links">
    <a href="/">home</a>
    <a href="/posts">posts</a>
    <a href="/about">about</a>
  </div>
  <div class="social-links">
    <a href="https://github.com/justanotherinternetguy" class="social-link" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
      <FaGithub client:idle class="icon" size={20} />
    </a>
    <a href="https://mastodon.social/@justanotherinternetguy" class="social-link" aria-label="Mastodon" target="_blank" rel="me noopener noreferrer">
      <FaMastodon client:idle class="icon" size={20} />
    </a>
  </div>
</nav>

<style>

</style>

<script>
(function () {
  const nav = document.querySelector('.site-nav') as HTMLElement | null;
  const marquee = document.querySelector('.marquee-banner') as HTMLElement | null;
  if (!nav || !marquee) return;

  let spacer: HTMLDivElement | null = null;
  let isScrolled = false;

  function getInset(): string {
    const vw = window.innerWidth;
    const bw = document.body.offsetWidth;
    const pct = Math.max(0, ((vw - bw) / 2 / vw) * 100);
    return pct.toFixed(2) + 'vw';
  }

  function enter() {
    if (isScrolled) return;
    isScrolled = true;

    const styles = getComputedStyle(nav!);
    const mTop = parseFloat(styles.marginTop) || 0;
    const mBot = parseFloat(styles.marginBottom) || 0;

    spacer = document.createElement('div');
    spacer.style.height = nav!.offsetHeight + mTop + mBot + 'px';
    nav!.parentElement!.insertBefore(spacer, nav);

    nav!.style.setProperty('--nav-inset', getInset());
    nav!.classList.add('nav-scrolled');
  }

  function leave() {
    if (!isScrolled) return;
    isScrolled = false;
    nav!.classList.remove('nav-scrolled');
    nav!.style.removeProperty('--nav-inset');
    // Wait two frames so sticky re-establishes before spacer is removed
    requestAnimationFrame(() => requestAnimationFrame(() => {
      spacer?.remove();
      spacer = null;
    }));
  }

  function onScroll() {
    if (marquee!.getBoundingClientRect().bottom <= 0) enter();
    else leave();
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  // Handle page loads that are already scrolled
  onScroll();
})();
</script>